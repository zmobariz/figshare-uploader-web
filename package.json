{
  "name": "bulk-uploader-for-figshare",
  "version": "2.1.0",
  "description": "Modern web app + CLI to bulk-create, update and manage Figshare articles from Excel/CSV spreadsheets.",
  "main": "electron/main.js",
  "type": "commonjs",
  "bin": {
    "figshare-upload": "cli.js"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "cli": "node cli.js",
    "desktop": "electron electron/main.js",
    "docker:build": "docker build -t bulk-uploader-for-figshare .",
    "docker:run": "docker run --rm -p 4000:4000 bulk-uploader-for-figshare",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "express": "^5.2.1",
    "multer": "^2.0.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "license": "MIT",
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zmobariz/bulk-uploader-for-figshare.git"
  },
  "overrides": {
    "tar": "7.5.16"
  }
}
